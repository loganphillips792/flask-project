{
  "uid": "sqlite-metrics",
  "title": "SQLite",
  "description": "SQLite query rate, latency and size for the Flask library API.",
  "tags": ["library", "flask", "sqlite"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Query rate",
      "description": "SQLite queries executed per second over the last minute.",
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "qps",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "sum(rate(db_queries_total[1m]))",
          "legendFormat": "queries/s",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "p95 query latency",
      "description": "95th percentile SQLite query duration over the last 5 minutes.",
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(db_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Query errors",
      "description": "Failed SQLite queries per second over the last 5 minutes.",
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "qps",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.001 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "sum(rate(db_queries_total{status=\"error\"}[5m])) or vector(0)",
          "legendFormat": "errors/s",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Query rate by operation",
      "description": "Queries per second broken down by SQL operation.",
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "qps",
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "sum by (operation) (rate(db_queries_total[1m]))",
          "legendFormat": "{{operation}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Query latency percentiles",
      "description": "p50 / p95 / p99 SQLite query duration.",
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 1, "fillOpacity": 0, "showPoints": "never" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "histogram_quantile(0.5, sum by (le) (rate(db_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(db_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(db_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Queries per HTTP request",
      "description": "Average SQLite queries executed per HTTP request — watch for N+1 regressions.",
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "sum(rate(db_queries_total[5m])) / clamp_min(sum(rate(flask_http_request_total{job=\"flask-app\"}[5m])), 1)",
          "legendFormat": "queries/request"
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "p95 latency by operation",
      "description": "Metrics-only stand-in for a slowest-queries list: which SQL operation is slowest. Per-statement detail would require query tracing.",
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "p95 latency", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 5,
          "custom": { "align": "auto" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "histogram_quantile(0.95, sum by (le, operation) (rate(db_query_duration_seconds_bucket[5m])))",
          "legendFormat": "{{operation}}",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": { "operation": "Operation", "Value": "p95 latency" }
          }
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Database file size",
      "description": "Size of the SQLite main and WAL files on disk.",
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "db_file_size_bytes",
          "legendFormat": "{{file}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Row counts by table",
      "description": "Number of rows in each table, sampled on scrape.",
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 1, "fillOpacity": 0, "showPoints": "auto" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "db_table_rows",
          "legendFormat": "{{table}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "logs",
      "title": "Recent queries",
      "description": "Every SQLite statement executed, newest first. Logged per query by app/db_metrics.py; SQL shown is the parameterized template.",
      "datasource": { "type": "loki", "uid": "loki_ds" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 28 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki_ds" },
          "expr": "{service_name=\"flask-app\"} | json | logger=\"app.db\" | line_format \"{{.operation}}  {{.duration_ms}}ms  {{.msg}}\"",
          "queryType": "range"
        }
      ]
    }
  ]
}
