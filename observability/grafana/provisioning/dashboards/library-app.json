{
  "uid": "library-app",
  "title": "Library App",
  "description": "Metrics, traces and logs for the Flask library API.",
  "tags": ["library", "flask"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Up",
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red", "index": 0 } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green", "index": 1 } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "up{job=\"flask-app\"}",
          "legendFormat": "up",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error rate (5xx)",
      "description": "Share of requests returning 5xx over the last 5 minutes.",
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "100 * (sum(rate(flask_http_request_total{job=\"flask-app\",status=~\"5..\"}[5m])) or vector(0)) / clamp_min(sum(rate(flask_http_request_total{job=\"flask-app\"}[5m])), 1)",
          "legendFormat": "5xx %",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Unhandled exceptions",
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.001 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "sum(rate(flask_http_request_exceptions_total{job=\"flask-app\"}[5m])) or vector(0)",
          "legendFormat": "exceptions/s",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Request rate by status",
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "sum by (status) (rate(flask_http_request_total{job=\"flask-app\"}[1m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "p95 latency by endpoint",
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 1, "fillOpacity": 0, "showPoints": "never" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(flask_http_request_duration_seconds_bucket{job=\"flask-app\"}[5m])))",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Span rate by name (from Tempo span metrics)",
      "description": "Generated by Tempo's metrics_generator and remote-written into Prometheus.",
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "sum by (span_name) (rate(traces_spanmetrics_calls_total{service=\"flask-app\"}[5m]))",
          "legendFormat": "{{span_name}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Application logs",
      "description": "Selects on service_name, the compose service label. Docker's own container names carry a leading slash.",
      "datasource": { "type": "loki", "uid": "loki_ds" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki_ds" },
          "expr": "{service_name=\"flask-app\"} | json | logger!=\"app.db\"",
          "queryType": "range"
        }
      ]
    }
  ]
}
