{
  "uid": "postgres-performance",
  "title": "Postgres Query Performance",
  "tags": ["postgres", "database", "provisioned"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datname",
        "label": "Database",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
        "query": "label_values(pg_stat_database_numbackends, datname)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Active Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "expr": "sum(pg_stat_database_numbackends{datname=~\"$datname\"})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Cache Hit Ratio",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_blks_hit{datname=~\"$datname\"}[5m])) / (sum(rate(pg_stat_database_blks_hit{datname=~\"$datname\"}[5m])) + sum(rate(pg_stat_database_blks_read{datname=~\"$datname\"}[5m])))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Deadlocks (5m rate)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_deadlocks{datname=~\"$datname\"}[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.001 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Rollback Ratio",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_xact_rollback{datname=~\"$datname\"}[5m])) / (sum(rate(pg_stat_database_xact_commit{datname=~\"$datname\"}[5m])) + sum(rate(pg_stat_database_xact_rollback{datname=~\"$datname\"}[5m])))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.2 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Transactions per second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "expr": "sum by (datname) (rate(pg_stat_database_xact_commit{datname=~\"$datname\"}[5m]))",
          "legendFormat": "commit · {{datname}}",
          "refId": "A"
        },
        {
          "expr": "sum by (datname) (rate(pg_stat_database_xact_rollback{datname=~\"$datname\"}[5m]))",
          "legendFormat": "rollback · {{datname}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 6,
      "title": "Rows returned / fetched / modified",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_tup_returned{datname=~\"$datname\"}[5m]))",
          "legendFormat": "returned (seq scan)",
          "refId": "A"
        },
        {
          "expr": "sum(rate(pg_stat_database_tup_fetched{datname=~\"$datname\"}[5m]))",
          "legendFormat": "fetched (index)",
          "refId": "B"
        },
        {
          "expr": "sum(rate(pg_stat_database_tup_inserted{datname=~\"$datname\"}[5m]))",
          "legendFormat": "inserted",
          "refId": "C"
        },
        {
          "expr": "sum(rate(pg_stat_database_tup_updated{datname=~\"$datname\"}[5m]))",
          "legendFormat": "updated",
          "refId": "D"
        },
        {
          "expr": "sum(rate(pg_stat_database_tup_deleted{datname=~\"$datname\"}[5m]))",
          "legendFormat": "deleted",
          "refId": "E"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "rowsps" }
      }
    },
    {
      "id": 7,
      "title": "Query calls per second (top 10 queryids)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "expr": "topk(10, sum by (queryid) (rate(pg_stat_statements_calls_total{datname=~\"$datname\"}[5m])))",
          "legendFormat": "{{queryid}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 8,
      "title": "Mean query time (top 10 slowest)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "expr": "topk(10, sum by (queryid) (rate(pg_stat_statements_seconds_total{datname=~\"$datname\"}[5m])) / sum by (queryid) (rate(pg_stat_statements_calls_total{datname=~\"$datname\"}[5m])))",
          "legendFormat": "{{queryid}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 9,
      "title": "Top 10 slowest queries (mean latency)",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "expr": "topk(10, sum by (queryid, datname, user) (rate(pg_stat_statements_seconds_total{datname=~\"$datname\"}[5m])) / sum by (queryid, datname, user) (rate(pg_stat_statements_calls_total{datname=~\"$datname\"}[5m])))",
          "instant": true,
          "format": "table",
          "refId": "A"
        },
        {
          "expr": "sum by (queryid, datname, user) (rate(pg_stat_statements_calls_total{datname=~\"$datname\"}[5m]))",
          "instant": true,
          "format": "table",
          "refId": "B"
        },
        {
          "expr": "sum by (queryid, datname, user) (rate(pg_stat_statements_rows_total{datname=~\"$datname\"}[5m]))",
          "instant": true,
          "format": "table",
          "refId": "C"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "queryid", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time 1": true, "Time 2": true, "Time 3": true, "datname 2": true, "datname 3": true, "user 2": true, "user 3": true },
            "renameByName": {
              "queryid": "Query ID",
              "datname 1": "Database",
              "user 1": "User",
              "Value #A": "Mean latency (s)",
              "Value #B": "Calls/s",
              "Value #C": "Rows/s"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Mean latency (s)" },
            "properties": [{ "id": "unit", "value": "s" }]
          },
          {
            "matcher": { "id": "byName", "options": "Calls/s" },
            "properties": [{ "id": "unit", "value": "ops" }]
          },
          {
            "matcher": { "id": "byName", "options": "Rows/s" },
            "properties": [{ "id": "unit", "value": "rowsps" }]
          }
        ]
      }
    },
    {
      "id": 10,
      "title": "Top 20 queries — full SQL text (from pg_stat_statements)",
      "type": "table",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 31 },
      "datasource": { "type": "postgres", "uid": "postgres_ds" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  d.datname AS \"Database\",\n  s.queryid::text AS \"Query ID\",\n  s.calls AS \"Calls\",\n  round(s.mean_exec_time::numeric, 2) AS \"Mean (ms)\",\n  round(s.total_exec_time::numeric, 2) AS \"Total (ms)\",\n  s.rows AS \"Rows\",\n  round((100.0 * s.shared_blks_hit / NULLIF(s.shared_blks_hit + s.shared_blks_read, 0))::numeric, 1) AS \"Cache hit %\",\n  s.query AS \"SQL\"\nFROM pg_stat_statements s\nJOIN pg_database d ON d.oid = s.dbid\nWHERE d.datname IN (${datname:sqlstring})\nORDER BY s.mean_exec_time DESC\nLIMIT 20;"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "filterable": true } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "SQL" },
            "properties": [{ "id": "custom.width", "value": 600 }]
          },
          {
            "matcher": { "id": "byName", "options": "Mean (ms)" },
            "properties": [{ "id": "unit", "value": "ms" }]
          },
          {
            "matcher": { "id": "byName", "options": "Total (ms)" },
            "properties": [{ "id": "unit", "value": "ms" }]
          }
        ]
      }
    }
  ]
}
